DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/creator_universe?schema=public"
PORT=4000
# Comma-separated origins allowed to call the API in browsers.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,https://project-limyoobins-projects.vercel.app"

# Development-only convenience. Keep this false in production.
ALLOW_INSECURE_USER_CONTEXT=false

# Optional. Set these only when you intentionally want to create/update an admin account.
# Never use weak sample passwords in production.
# ROOT_ADMIN_USERNAME=root
# ROOT_ADMIN_PASSWORD=replace-with-a-long-unique-password
# ROOT_ADMIN_EMAIL=root@creator-universe.local
